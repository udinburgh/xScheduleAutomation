# =========================================================================
# X (Twitter) Tweet Scheduler - Configuration
# =========================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# -------------------------------------------------------------------------
# Google Sheets API Endpoint (REQUIRED)
# -------------------------------------------------------------------------
# Your Apps Script web app URL. See README.md for setup steps.
# Should return JSON array: [{ content, date, time, image_url, account }]
SHEET_API_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# -------------------------------------------------------------------------
# X (Twitter) Cookies — Single-account mode ONLY
# -------------------------------------------------------------------------
# Skip these if you use accounts.json (multi-account mode).
# Otherwise:
#   1. Login to x.com
#   2. Open DevTools (F12) → Application → Cookies → x.com
#   3. Copy values of auth_token and ct0
X_AUTH_TOKEN=
X_CT0=

# -------------------------------------------------------------------------
# Browser Settings
# -------------------------------------------------------------------------
# true  → headless (no browser window, faster)
# false → visible browser (recommended for first run, can intervene manually)
HEADLESS=false
